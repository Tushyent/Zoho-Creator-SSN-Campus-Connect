	reports
	{
		list doubt_response_Report
		{
			displayName = "All Doubt Responses"
			show all rows from doubt_response    
			(
				doubt as "Doubt"
				response_by as "Response By"
				content as "Content"
				is_accepted as "Is Accepted"
				upvotes as "Upvotes"
				created_at as "Created At"
			)
		}
		list helpdesk_issue_Report
		{
			displayName = "All Helpdesk Issues"
			show all rows from helpdesk_issue    
			(
				title as "Title"
				description as "Description"
				reported_by as "Reported By"
				issue_type as "Issue Type"
				status as "Status"
				priority as "Priority"
				created_at as "Created At"
				updated_at as "Updated At"
				assigned_to as "Assigned To"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (priority == "High")
				fields = [priority]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (priority == "Low")
				fields = [priority]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (priority == "URGENT")
				fields = [priority]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban helpdesk_issue_by_priority
		{
			displayName = "Priorities"
			show all rows from helpdesk_issue    
			(
				title as "Title"
				description as "Description"
