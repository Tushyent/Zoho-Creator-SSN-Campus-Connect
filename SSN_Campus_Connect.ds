	 			column = 1   
				width = medium
			)
			current_role
			(
    			type = text
				displayname = "Current Role"
	 			row = 1
	 			column = 1   
				width = medium
			)
			branch
			(
				type = picklist
				displayname = "Branch"
				values = {"CIVIL","CSE","EEE","ECE","MECH","AIML","IT"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			skills
			(
				type = list	
				displayname = "Skills"
				values = {"DSA","Cloud Computing","Networking","Data Analysis","Web Development","Machine Learning"}
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			profile_image
			(
    			type = url
				displayname = "Profile Image"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
